# UNICARE Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for AI features — voice & text chat)
# Get your key at https://aistudio.google.com/apikey
VITE_GOOGLE_API_KEY=your-google-api-key-here

# Firebase Configuration (required for authentication & user data)
# Get these from https://console.firebase.google.com → Project Settings → General
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
